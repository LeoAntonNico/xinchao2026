generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String
  phone       String
  email       String?
  openTime    String
  closeTime   String
  openingHours Json? // { "monday": { "open": "12:00", "close": "20:00" }, ... }
  welcomeTextNl String?
  welcomeTextEn String?
  capacity    Int
  mapEmbedUrl String?
  createdAt   DateTime @default(now())
  nextOrderNumber Int  @default(999)

  menuItems              MenuItem[]
  plasticSurcharges      ProductPlasticSurcharge[]
  pickupSlots            PickupSlot[]
  reservations           Reservation[]
  reservationDaySettings ReservationDaySetting[]
  orders                 Order[]
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model MenuCategory {
  id        String @id @default(uuid())
  name      String
  slug      String @unique
  sortOrder Int    @default(0)

  items MenuItem[]
}

model MenuItem {
  id               String  @id @default(uuid())
  name             String
  nameNl           String?
  shortDescriptionNl String?
  descriptionNl    String?
  description      String? // long description
  shortDescription String? // short excerpt
  price            Int // cents (EUR) — base price
  salePrice        Int? // cents — strike-through promotional price
  taxClass         String  @default("standard") // standard, reduced, zero, alcohol
  imageUrl         String? // legacy primary image
  imageUrls        String[] @default([]) // photo gallery
  isAvailable      Boolean @default(true)
  isDineInOnly     Boolean @default(false)
  sortOrder        Int     @default(0)

  dietaryTags String[] @default([])
  isSpicy     Boolean  @default(false)

  categories MenuCategory[]
  locations  Location[]
  orderItems OrderItem[]
  variants   ProductVariant[]
  modifiers  ProductModifier[]
  exclusions ProductExclusion[]
  plasticSurcharges ProductPlasticSurcharge[]
}

model ProductPlasticSurcharge {
  id        String  @id @default(uuid())
  amount    Int     @default(0) // cents
  isActive  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItemId String
  locationId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, locationId])
}

model ProductExclusion {
  id        String  @id @default(uuid())
  name      String
  nameNl    String?
  sortOrder Int     @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model DietaryOption {
  id      String  @id @default(uuid())
  slug    String  @unique // e.g. "vegan", "gluten-free"
  nameEn  String
  nameNl  String
  iconUrl String? // uploaded icon image
  sortOrder Int   @default(0)
}

model ProductVariant {
  id        String  @id @default(uuid())
  name      String
  nameNl    String?
  price     Int // cents — override price for this variant (0 = same as base)
  sortOrder Int     @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model ProductModifier {
  id        String  @id @default(uuid())
  name      String
  nameNl    String?
  price     Int    @default(0) // cents — added to order total
  sortOrder Int    @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model PickupSlot {
  id       String   @id @default(uuid())
  date     DateTime @db.Date
  time     String
  capacity Int
  booked   Int      @default(0)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  orders Order[]

  @@unique([locationId, date, time])
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String?     @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Int // cents
  customerName    String
  customerPhone   String
  customerEmail   String?
  notes           String?
  molliePaymentId String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())

  locationId   String
  pickupSlotId String
  customerId   String?
  location     Location   @relation(fields: [locationId], references: [id])
  pickupSlot   PickupSlot @relation(fields: [pickupSlotId], references: [id])
  customer     Customer?  @relation(fields: [customerId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id            String @id @default(uuid())
  quantity      Int
  price         Int // snapshot at time of order (cents)
  variantId     String?
  variantName   String?
  modifierIds   String[] @default([])
  modifierNames String[] @default([])
  exclusionIds   String[] @default([])
  exclusionNames String[] @default([])

  orderId    String
  menuItemId String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Reservation {
  id            String            @id @default(uuid())
  date          DateTime          @db.Date
  time          String
  partySize     Int
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  status        ReservationStatus @default(CONFIRMED)
  createdAt     DateTime          @default(now())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])
}

model ReservationDaySetting {
  id                  String   @id @default(uuid())
  date                DateTime @db.Date
  reservationsEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, date])
}

model PrintJob {
  id          String      @id @default(cuid())
  orderId     String?
  location    String      // "utrecht" | "wageningen"
  payload     Json        // receipt data template
  escposData  String?     // pre-rendered ESC/POS base64
  status      PrintStatus @default(PENDING)
  printedAt   DateTime?
  attemptCount Int        @default(0)
  lastError   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum PrintStatus {
  PENDING
  PRINTED
  FAILED
  RETRYING
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}
