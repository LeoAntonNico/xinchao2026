generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Location {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String
  phone       String
  email       String?
  openTime    String
  closeTime   String
  capacity    Int
  mapEmbedUrl String?
  createdAt   DateTime @default(now())

  menuItems    MenuItem[]
  pickupSlots  PickupSlot[]
  reservations Reservation[]
  orders       Order[]
}

model MenuCategory {
  id        String @id @default(uuid())
  name      String
  slug      String @unique
  sortOrder Int    @default(0)

  items MenuItem[]
}

model MenuItem {
  id               String  @id @default(uuid())
  name             String
  description      String? // long description
  shortDescription String? // short excerpt
  price            Int // cents (EUR) — base price
  salePrice        Int? // cents — strike-through promotional price
  taxClass         String  @default("standard") // standard, reduced, zero, alcohol
  imageUrl         String? // legacy primary image
  imageUrls        String[] @default([]) // photo gallery
  isAvailable      Boolean @default(true)
  sortOrder        Int     @default(0)

  dietaryTags String[] @default([])
  isSpicy     Boolean  @default(false)

  categories MenuCategory[]
  locations  Location[]
  orderItems OrderItem[]
  variants   ProductVariant[]
  modifiers  ProductModifier[]
}

model ProductVariant {
  id        String @id @default(uuid())
  name      String
  price     Int // cents — override price for this variant (0 = same as base)
  sortOrder Int    @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model ProductModifier {
  id        String @id @default(uuid())
  name      String
  price     Int    @default(0) // cents — added to order total
  sortOrder Int    @default(0)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model PickupSlot {
  id       String   @id @default(uuid())
  date     DateTime @db.Date
  time     String
  capacity Int
  booked   Int      @default(0)

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  orders Order[]

  @@unique([locationId, date, time])
}

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  totalAmount     Int // cents
  customerName    String
  customerPhone   String
  customerEmail   String?
  notes           String?
  molliePaymentId String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())

  locationId   String
  pickupSlotId String
  location     Location   @relation(fields: [locationId], references: [id])
  pickupSlot   PickupSlot @relation(fields: [pickupSlotId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Int // snapshot at time of order (cents)

  orderId    String
  menuItemId String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Reservation {
  id            String            @id @default(uuid())
  date          DateTime          @db.Date
  time          String
  partySize     Int
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?
  status        ReservationStatus @default(CONFIRMED)
  createdAt     DateTime          @default(now())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}
