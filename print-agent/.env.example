XINCHAO_BASE_URL=https://your-domain.example
XINCHAO_PRINT_SECRET=change-me
XINCHAO_LOCATION=utrecht

# tcp = Epson LAN printer on port 9100
# share = Windows shared printer path, useful for USB printers
# file = testing only, writes ESC/POS files to ./printed
XINCHAO_TRANSPORT=tcp

# TCP settings
XINCHAO_PRINTER_HOST=192.168.1.50
XINCHAO_PRINTER_PORT=9100

# Windows shared printer settings
# Example: \\RESTAURANT-PC\EPSON-TM-T20III
XINCHAO_PRINTER_SHARE=

XINCHAO_POLL_MS=4000
XINCHAO_MAX_ATTEMPTS=5
XINCHAO_LOG_FILE=logs/print-agent.log
